<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/header_margin_horizontal"
    android:paddingEnd="@dimen/header_margin_horizontal"
    android:paddingTop="16dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="?shapeAppearanceCornerExtraLarge"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@tools:sample/backgrounds/scenic[5]" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:ellipsize="end"
        android:textAlignment="center"
        android:textAppearance="?textAppearanceTitleLargeEmphasized"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="@tools:sample/cities" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:textAlignment="center"
        android:textAppearance="?textAppearanceTitleMedium"
        app:layout_constraintTop_toBottomOf="@+id/title"
        app:layout_constraintStart_toStartOf="@+id/title"
        app:layout_constraintEnd_toEndOf="@+id/title"
        tools:text="@tools:sample/full_names" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/shuffleAction"
        style="?materialIconButtonFilledTonalStyle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="@string/shuffle_action"
        app:icon="@drawable/ic_shuffle_24dp"
        app:layout_constraintTop_toTopOf="@+id/playAction"
        app:layout_constraintBottom_toBottomOf="@+id/playAction"
        app:layout_constraintEnd_toStartOf="@+id/playAction"/>

    <ImageView
        android:id="@+id/playAction"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        android:contentDescription="@string/action_play"
        android:background="@drawable/cookie_shape"
        android:backgroundTint="?colorPrimary"
        android:padding="24dp"
        app:srcCompat="@drawable/ic_play_24dp"
        app:tint="?colorOnPrimary"
        app:layout_constraintTop_toBottomOf="@+id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/searchAction"
        style="?materialIconButtonFilledTonalStyle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="8dp"
        android:contentDescription="@string/search_label"
        app:icon="@drawable/ic_search_24dp"
        app:layout_constraintTop_toTopOf="@+id/playAction"
        app:layout_constraintBottom_toBottomOf="@+id/playAction"
        app:layout_constraintStart_toEndOf="@+id/playAction"/>

</androidx.constraintlayout.widget.ConstraintLayout>